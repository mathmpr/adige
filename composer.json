{
  "name": "trentino-alto/adige",
  "type": "library",
  "description": "A small PHP framework with HTTP, console, ORM, migrations, views and validation support.",
  "keywords": [
    "php",
    "framework",
    "web",
    "console",
    "mvc",
    "orm",
    "activerecord",
    "migration",
    "validation"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Matheus Prado Rodrigues",
      "email": "matheus@mathmpr.com"
    }
  ],
  "support": {
    "issues": "https://github.com/mathmpr/adige/issues",
    "source": "https://github.com/mathmpr/adige"
  },
  "minimum-stability": "stable",
  "autoload": {
    "psr-4": {
      "Adige\\": "src/"
    },
    "files": [
      "src/helpers/functions.php"
    ]
  },
  "bin": [
    "bin/adige"
  ],
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "tests\\Fixtures\\web\\": "tests/Fixtures/web/"
    }
  },
  "require": {
    "php": "^8.2",
    "ext-fileinfo": "*",
    "ext-readline": "*",
    "ext-sockets": "*",
    "ext-pcntl": "*",
    "ext-posix": "*",
    "ext-mbstring": "*",
    "ext-ctype": "*",
    "ext-pdo": "*",
    "voku/portable-ascii": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5.8"
  }
}
